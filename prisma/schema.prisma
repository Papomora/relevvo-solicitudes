generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientePin {
  id      Int    @id @default(autoincrement())
  cliente String @unique
  pin     String
}

model Solicitud {
  id          Int      @id @default(autoincrement())
  cliente     String
  tipo        String
  urgencia    String
  descripcion String
  estado      String   @default("pendiente")
  nota        String?
  perfil      String?
  adjuntos    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
